#!/usr/bin/env -S deno run --allow-read --allow-write=/tmp --allow-run=cue,diff --allow-env
//MISE description="Run golden file tests via cue vet"

import $ from "jsr:@david/dax@0.47.0";
import { red, green } from "jsr:@std/fmt/colors";

$.setInfoLogger(console.log);
$.setWarnLogger(console.log);
$.setErrorLogger(console.log);

const pattern = /^(.*?): conflicting values (".*?") and (".*?"):/;

async function formatErrors(stderr: string): Promise<void> {
  for (const line of stderr.split("\n")) {
    const m = line.match(pattern);
    if (!m) {
      if (!line.startsWith("    ") && line.trim()) {
        console.log(line);
      }
      continue;
    }

    const field = m[1];
    let a: string, b: string;
    try {
      a = JSON.parse(m[2]);
      b = JSON.parse(m[3]);
    } catch {
      console.log(line);
      continue;
    }

    const ef = await Deno.makeTempFile();
    const af = await Deno.makeTempFile();
    try {
      await Deno.writeTextFile(ef, a);
      await Deno.writeTextFile(af, b);
      await $`diff --color=always -u --label ${"expected  " + field} --label ${"actual    " + field} ${ef} ${af}`
        .noThrow();
    } finally {
      await Deno.remove(ef);
      await Deno.remove(af);
    }
  }
}

const testingDir = $.path("testing");
let passed = 0;
let failed = 0;

for await (const entry of testingDir.readDir()) {
  if (!entry.isDirectory() || entry.name === "cue.mod") continue;

  const result = await $`cue vet ./${entry.name}`.cwd(testingDir).noThrow().stderr("piped");

  if (result.code === 0) {
    $.log(green(`PASS  ${entry.name}`));
    passed++;
  } else {
    $.log(red(`FAIL  ${entry.name}`));
    failed++;
    await formatErrors(result.stderr);
  }
}

$.log(`\nResults: ${passed} passed, ${failed} failed`);
if (failed > 0) {
  Deno.exit(1);
}
