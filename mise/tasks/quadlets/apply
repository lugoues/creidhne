#!/usr/bin/env -S deno run --allow-all
//MISE description="Write generated quadlet files to the quadlet directory"

import { $, red, green, yellow, dim, getFiles, getQuadletDir, computePlan, planSummary, isWritable, writeFile, removeFile, mkdirp } from "./lib.ts";

const dir = getQuadletDir();
const files = await getFiles();
const target = $.path(dir);

// Check if we need elevated permissions
const dirExists = await target.exists();
const elevated = dirExists ? !(await isWritable(dir)) : false;

if (elevated) {
  $.logWarn(`${dir} requires elevated permissions`);
}

await mkdirp(dir, elevated);

const changes = await computePlan(files, dir);
const { added, changed, unchanged, removed, total } = planSummary(changes);

// Show plan
for (const c of changes) {
  switch (c.action) {
    case "add":    $.log(green(`  + ${c.name}`)); break;
    case "change": $.log(yellow(`  ~ ${c.name}`)); break;
    case "unchanged": $.log(dim(`    ${c.name} (unchanged)`)); break;
    case "remove": $.log(red(`  - ${c.name}`)); break;
  }
}

$.log(`\n${total} file(s): ${added} to add, ${changed} to update, ${unchanged} unchanged, ${removed} to remove`);

if (added === 0 && changed === 0 && removed === 0) {
  $.log("Nothing to do.");
  Deno.exit(0);
}

if (!await $.confirm("Apply changes?", { default: false })) {
  $.log("Aborted.");
  Deno.exit(0);
}

// Apply
for (const c of changes) {
  switch (c.action) {
    case "add":
    case "change":
      await writeFile(target.join(c.name).toString(), c.content, elevated);
      break;
    case "remove":
      await removeFile(target.join(c.name).toString(), elevated);
      break;
  }
}

$.log(`\nApplied: ${added} added, ${changed} updated, ${removed} removed`);
const reloadCmd = elevated ? "systemctl daemon-reload" : "systemctl --user daemon-reload";
$.log(`Run '${reloadCmd}' to pick up changes.`);
