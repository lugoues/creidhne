#!/usr/bin/env -S deno run --allow-all
//MISE description="Diff generated quadlet files against the live quadlet directory"

import { $, red, green, yellow, getFiles, getQuadletDir, computePlan, planSummary, runDiff } from "./lib.ts";

const dir = getQuadletDir();
const files = await getFiles();
const changes = await computePlan(files, dir);
const { added, changed, unchanged, removed, total } = planSummary(changes);

for (const c of changes) {
  switch (c.action) {
    case "add":
      $.log(green(`+ ${c.name} (new)`));
      $.log(c.content.split("\n").map((l: string) => `  ${l}`).join("\n"));
      $.log("");
      break;
    case "change":
      $.log(yellow(`~ ${c.name} (changed)`));
      $.log(await runDiff($.path(dir).join(c.name).toString(), c.content, `live/${c.name}`, `new/${c.name}`));
      break;
    case "remove":
      $.log(red(`- ${c.name} (stale, will be removed)`));
      break;
  }
}

$.log(`\n${total} file(s): ${added} new, ${changed} changed, ${unchanged} unchanged, ${removed} stale`);
