#!/usr/bin/env -S deno run --allow-all
//MISE description="Show what apply would do without making changes"

import { $, red, green, yellow, dim, getFiles, getQuadletDir, computePlan, planSummary } from "./lib.ts";

const dir = getQuadletDir();
const files = await getFiles();
const changes = await computePlan(files, dir);
const { added, changed, unchanged, removed, total } = planSummary(changes);

for (const c of changes) {
  switch (c.action) {
    case "add":
      $.log(green(`  + ${c.name} (add)`));
      break;
    case "change":
      $.log(yellow(`  ~ ${c.name} (update)`));
      break;
    case "unchanged":
      $.log(dim(`    ${c.name} (unchanged)`));
      break;
    case "remove":
      $.log(red(`  - ${c.name} (remove)`));
      break;
  }
}

$.log(`\n${total} file(s): ${added} to add, ${changed} to update, ${unchanged} unchanged, ${removed} to remove`);
if (added === 0 && changed === 0 && removed === 0) {
  $.log("Nothing to do.");
}
